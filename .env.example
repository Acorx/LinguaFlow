# ==========================================
# LinguaFlow — Configuration
# Copier ce fichier en .env et remplir les valeurs
# ==========================================

# --- API PROVIDERS ---
# OpenRouter (multi-modèles: Claude, GPT, Gemini, DeepSeek)
OPENROUTER_API_KEY=sk-or-...

# OpenAI (Whisper STT + TTS + GPT-4o)
OPENAI_API_KEY=sk-...

# --- LOCAL PROVIDERS ---
# Ollama (détection auto si ollama tourne sur localhost:11434)
OLLAMA_HOST=http://localhost:11434

# --- PROFIL PAR DÉFAUT ---
# Langue cible (ISO 639-1): en, fr, es, de, it, pt, ja, zh, ar, ru...
LANGUAGE_TARGET=en

# Niveau: beginner, intermediate, advanced
LANGUAGE_LEVEL=intermediate

# Mode: auto (détecte dispo), api (force API), local (force local)
PROVIDER_MODE=auto

# Modèle LLM (optionnel — sinon auto-sélection)
# API: anthropic/claude-sonnet-4-20250514, openai/gpt-4o-mini, deepseek/deepseek-chat
# Local: llama3.2:3b, qwen2.5:3b
LLM_MODEL=

# --- TTS ---
# API: openai, Local: piper
TTS_PROVIDER=auto

# --- STT ---
# API: openai, Local: whispercpp
STT_PROVIDER=auto
